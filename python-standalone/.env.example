# DermaAI Environment Variables
# Copy this file to .env and fill in your values

# Database (leave blank to use SQLite - recommended for local dev)
DATABASE_URL=sqlite:///dermaai.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/dermaai

# Flask Secret Key (change this in production!)
SECRET_KEY=dermaai-pakistan-2024-change-in-production

# Server Configuration
PORT=5000
DEBUG=true
HOST=0.0.0.0
